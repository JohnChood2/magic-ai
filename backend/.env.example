# Copy to .env and fill in your values.
# Never commit the real .env file.

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model identifier. claude-sonnet-4-6 is a good default for quality+latency.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Scryfall API base. Override only if mocking in tests.
SCRYFALL_API_BASE=https://api.scryfall.com

# Required User-Agent for Scryfall — Scryfall asks fan projects to identify themselves.
SCRYFALL_USER_AGENT=MagicGPT/0.1 (https://github.com/your-org/magic-ai)

# CORS — comma-separated list of origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Environment name shown by /health
ENV=development
